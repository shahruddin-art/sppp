generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // ADMIN, KAUNTER, PT, PPKP_L, PPKP_P, PPL_L, PPL_P, PLB
  zone      String?  // A, B, C, D, E (null for ADMIN, KAUNTER, PLB)
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedSteps    WorkflowStep[]  @relation("StepAssignedUser")
  ptApplications   Application[]  @relation("PTAssigned")
  ppkpApplications Application[]  @relation("PPKPAssigned")
  pplApplications  Application[]  @relation("PPLAssigned")
  plbApplications  Application[]  @relation("PLBAssigned")
}

model Application {
  id               String   @id @default(cuid())
  referenceNo      String   @unique
  applicantName    String
  applicantIc      String
  applicantPhone   String?
  applicantAddress String?
  applicationType  String   // PERMOHONAN_BARU, TUKAR_NAMA_SYARIKAT, TAMBAH_KURANG_PREMIS, TAMBAH_TUKAR_AKTIVITI, PINDAH_MILIK_LESEN
  businessType     String?  // Jenis perniagaan (for PERMOHONAN_BARU)
  businessName     String?  // Nama Perniagaan (for sticker)
  accountNo        String?  // No. Akaun (for sticker)
  zone             String
  status           String
  fileNumber       String?
  currentStep      String
  ptStaffId        String?
  ppkpStaffId      String?
  pplStaffId       String?
  plbStaffId       String?
  plbDecision       String?
  plbDecisionNotes  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ptStaff    User?         @relation("PTAssigned", fields: [ptStaffId], references: [id])
  ppkpStaff  User?         @relation("PPKPAssigned", fields: [ppkpStaffId], references: [id])
  pplStaff   User?         @relation("PPLAssigned", fields: [pplStaffId], references: [id])
  plbStaff   User?         @relation("PLBAssigned", fields: [plbStaffId], references: [id])
  steps      WorkflowStep[]
}

model WorkflowStep {
  id            String    @id @default(cuid())
  applicationId String
  step          String
  status        String
  assignedToId  String?
  startedAt     DateTime?
  completedAt   DateTime?
  slaDays       Float
  slaDeadline   DateTime?
  comments      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignedTo  User?       @relation("StepAssignedUser", fields: [assignedToId], references: [id])
}

model KpiConfig {
  id          String   @id @default(cuid())
  stepName    String   @unique
  slaDays     Float
  warningDays Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationType {
  id         String   @id @default(cuid())
  code       String   @unique
  label      String
  ppkpRoute  String   @default("PPKP_L")  // PPKP_L or PPKP_P
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
