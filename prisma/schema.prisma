generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // ADMIN, KAUNTER, PT, PPKP_L, PPKP_P, PPL_L, PPL_P, PLB
  zone      String?  // A, B, C, D, E (null for ADMIN, KAUNTER, PLB)
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedSteps   WorkflowStep[]  @relation("StepAssignedUser")
  ptApplications  Application[] @relation("PTAssigned")
  ppkpApplications Application[] @relation("PPKPAssigned")
  pplApplications Application[] @relation("PPLAssigned")
  plbApplications Application[] @relation("PLBAssigned")
}

model Application {
  id              String   @id @default(cuid())
  referenceNo     String   @unique
  applicantName   String
  applicantIc     String
  applicantPhone  String?
  applicantAddress String?
  applicationType String   // G1, G1_P, G2, G3, G7, G8, G9, G11, PAPAN_IKLAN, PERMIT_SEMENTARA
  zone            String   // A, B, C, D, E
  status          String   // PENDING_PT, PT_PROCESSING, PPKP_PROCESSING, PPL_REVIEW, PLB_DECISION, COMPLETED, REJECTED
  fileNumber      String?
  currentStep     String   // KAUNTER, PT_FILE_OPENING, PT_FILE_REGISTRATION, PPKP_PROCESSING, PPL_REVIEW, PLB_DECISION
  ptStaffId       String?
  ppkpStaffId     String?
  pplStaffId      String?
  plbStaffId      String?
  plbDecision      String?  // SIMPAN_FAIL, JABATAN_KESIHATAN, JABATAN_PERANCANG_BANDAR
  plbDecisionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ptStaff    User?         @relation("PTAssigned", fields: [ptStaffId], references: [id])
  ppkpStaff  User?         @relation("PPKPAssigned", fields: [ppkpStaffId], references: [id])
  pplStaff   User?         @relation("PPLAssigned", fields: [pplStaffId], references: [id])
  plbStaff   User?         @relation("PLBAssigned", fields: [plbStaffId], references: [id])
  steps      WorkflowStep[]
}

model WorkflowStep {
  id            String   @id @default(cuid())
  applicationId String
  step          String   // KAUNTER_RECEIPT, PT_FILE_OPENING, PT_FILE_REGISTRATION, PPKP_PROCESSING, PPL_REVIEW, PLB_DECISION
  status        String   // PENDING, IN_PROGRESS, COMPLETED, OVERDUE
  assignedToId  String?
  startedAt     DateTime?
  completedAt   DateTime?
  slaDays       Float    // SLA in days
  slaDeadline   DateTime?
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignedTo  User?       @relation("StepAssignedUser", fields: [assignedToId], references: [id])
}

model KpiConfig {
  id          String   @id @default(cuid())
  stepName    String   @unique // PT_FILE_OPENING, PPKP_PROCESSING, PPL_REVIEW
  slaDays     Float    // SLA in days
  warningDays Float    // Days before deadline to show warning
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
